<view class="container">
  <view class="title">查询</view>

  <view class="input-area">
    <input
      class="input-item-full"
      type="number"
      placeholder="请输入11位手机号"
      bindinput="inputPhone"
      maxlength="11"
      value="{{phone}}"
    />
  </view>

  <button
    class="query-btn"
    bindtap="onQueryTap"
    disabled="{{!canQuery}}"
    loading="{{isLoading}}"
  >
    查找
  </button>

  <view class="result-area" wx:if="{{showResult}}">
    <view class="result-phone">{{displayPhone}}</view>
    <view class="result-text {{result === '是骚扰电话' ? 'danger' : 'success'}}">
      {{result === '是骚扰电话' ? '是' : '不是'}}
    </view>
  </view>

  <view class="history-btn" bindtap="toHistory">查看查询历史</view>
  <view class="admin-btn" bindtap="toAdmin">管理员后台</view>
</view>
