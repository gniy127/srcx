.container {
  padding: 40rpx 30rpx;
}

.pwd-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pwd-input {
  width: 80%;
  height: 80rpx;
  border: 1rpx solid #ccc;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 32rpx;
  margin-bottom: 40rpx;
}

.login-btn {
  width: 80%;
  height: 80rpx;
  background-color: #1677ff;
  color: #fff;
  border-radius: 8rpx;
}

.admin-area {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.data-status {
  font-size: 28rpx;
  color: #666;
}

.import-area {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.import-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #ccc;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.import-btn {
  width: 80%;
  height: 70rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 8rpx;
}

/* Excel导入样式 */
.excel-import-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx dashed #ccc;
}

/* 手动导入textarea样式 */
.import-textarea {
  width: 90%;
  height: 200rpx; 
  max-height: 200rpx; 
  border: 1px solid #ccc;
  padding: 20rpx;
  box-sizing: border-box;
  margin: 20rpx auto;
  border-radius: 8rpx;
  overflow-y: auto; /* 内容超出时显示垂直滚动条 */
  resize: none; /* 禁止用户手动拖动调整大小 */
}

.excel-btn {
  width: 80%;
  height: 70rpx;
  background-color: #1677ff;
  color: #fff;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.file-tip {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 20rpx;
}

.excel-import-btn {
  width: 80%;
  height: 70rpx;
  background-color: #07c160;
  color: #fff;
  border-radius: 8rpx;
}

.operate-area {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.operate-btn {
  width: 40%;
  height: 70rpx;
  border-radius: 8rpx;
}

.danger {
  background-color: #f53f3f;
  color: #fff;
}

.logout-btn {
  width: 80%;
  height: 70rpx;
  margin: 0 auto;
  background-color: #ccc;
  color: #333;
  border-radius: 8rpx;
}