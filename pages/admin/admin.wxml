<view class="container">
  <!-- 密码验证 -->
  <view class="pwd-area" wx:if="{{!isLogin}}">
    <input 
      class="pwd-input" 
      type="password" 
      placeholder="请输入管理员密码" 
      bindinput="inputPwd"
      value="{{adminPwd}}"
    />
    <button class="login-btn" bindtap="checkPwd">登录</button>
  </view>

  <!-- 数据管理功能 -->
  <view class="admin-area" wx:else>
    <!-- 数据状态 -->
    <view class="data-status">
      当前已导入特征值数量：{{Object.keys(phoneMap).length}}
    </view>

    <!-- 方式1：手动输入导入 -->
    <view class="import-area">
      <textarea 
        class="import-textarea" 
        placeholder="输入11位手机号（批量用,分隔）" 
        bindinput="inputPhoneList"
        value="{{phoneList}}" 
        maxlength="-1" 
      />
      <button class="import-btn" bindtap="importPhone">手动导入号码</button>
    </view>

    <!-- 方式2：Excel文件导入 -->
    <view class="excel-import-area">
      <button class="excel-btn" bindtap="chooseExcelFile">选择Excel文件</button>
      <view class="file-tip" wx:if="{{fileName}}">已选择：{{fileName}}</view>
      <button class="excel-import-btn" bindtap="importExcelPhone" wx:if="{{fileName}}">导入Excel中的号码</button>
    </view>

    <!-- 数据操作 -->
    <view class="operate-area">
      <button class="operate-btn danger" bindtap="clearAll">清空所有数据</button>
      <button class="operate-btn" bindtap="exportData">导出数据</button>
    </view>

    <!-- 退出登录 -->
    <button class="logout-btn" bindtap="logout">退出登录</button>
  </view>
</view>